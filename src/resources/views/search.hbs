<div class="search-form mt-4">
  <form class="row g-3" action="" method="post">
    <div class="form-group">
      <label for="search-input">Từ khóa</label>
      <input type="text" name="q" class="form-control" id="search-input" autocomplete="off" placeholder="Tìm kiếm . . .">
    </div>
    <div class="form-group">
      <label for="gender-input">Giới tính</label>
      <select type="text" name="gender" class="form-control" id="gender-input">
        <option value="">-- Chọn giới tính --</option>
        <option value="male">Nam</option>
        <option value="female">Nữ</option>
      </select>
    </div>
    <div class="col-auto">
      <button type="submit" class="btn btn-primary mb-3">Tìm kiếm</button>
    </div>
  </form>
</div>